/* Titre d'une catégorie */


.cate_title {
    margin: -45px 0px 15px;
    padding: 50px 20px;
    text-align: center;
    color: var(--text);
    font: 19px Playfair Display;
    background-image: url(https://i.goopics.net/nbynhv.png);
