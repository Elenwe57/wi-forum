}


/* Lien spécial mis en avant */
.specials_links a,
a.specials_links {
  background: var(--neutralDark);
  padding: 2px 6px;
  border-radius: 5px;
}


/* Suppression des liens vides */
.specials_links a:empty,
a.specials_links:empty {
