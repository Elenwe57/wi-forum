/*** ------------------------------- ***/
/*** ELEMENTS ESTHETIQUES ---------- ***/


/* Contenur général qui sert généralement de fond et/ou de contour*/
.container {
  background: var(--neutralDarker);
  padding: 10px;
}


/* Barre de séparation */
.separator {
