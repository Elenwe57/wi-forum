  /*ne pas retirer*/
  width: 26px !important;
  /*ne pas retirer*/
}


/* Bouton d'un outil au survol ou actif*/
.sceditor-button.active,
.sceditor-button:active,
.sceditor-button:hover,
.sceditor-button.hover {
